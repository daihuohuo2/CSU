<view class="tab-bar">
  <view class="tab-bar-border"></view>
  <view wx:for="{{list}}" wx:key="index" class="tab-bar-item" data-path="{{item.pagePath}}" bindtap="switchTab">
    <!-- 首页图标 -->
    <view wx:if="{{index === 0}}" class="tab-icon">
      <view class="icon-home {{selected === 0 ? 'active' : ''}}"></view>
    </view>
    <!-- 我的图标 -->
    <view wx:if="{{index === 1}}" class="tab-icon">
      <view class="icon-mine {{selected === 1 ? 'active' : ''}}"></view>
    </view>
    <view class="tab-text {{selected === index ? 'text-active' : ''}}">{{item.text}}</view>
  </view>
</view>
