.tutorial-card {
  padding: 28rpx 30rpx;
}

.tutorial-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.tutorial-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.tutorial-category {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #F0FFF0;
  color: #07C160;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.tutorial-preview {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  line-height: 1.5;
}
