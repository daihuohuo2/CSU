<view class="container" wx:if="{{detail}}">
  <!-- 标题 -->
  <view class="tutorial-top card">
    <view class="tutorial-detail-title">{{detail.title}}</view>
    <view class="tutorial-detail-cat">{{detail.category}}</view>
  </view>

  <!-- 内容 -->
  <view class="card">
    <view class="section-header">动作要领</view>
    <view class="content-text">{{detail.content}}</view>
  </view>

  <view class="card" wx:if="{{detail.tips}}">
    <view class="section-header">注意事项</view>
    <view class="content-text tips-text">{{detail.tips}}</view>
  </view>

  <view class="card" wx:if="{{detail.commonMistakes}}">
    <view class="section-header">常见错误</view>
    <view class="content-text mistakes-text">{{detail.commonMistakes}}</view>
  </view>

  <view class="card" wx:if="{{detail.summary}}">
    <view class="section-header">训练总结</view>
    <view class="content-text summary-text">{{detail.summary}}</view>
  </view>

  <!-- 管理员操作 -->
  <view class="bottom-actions" wx:if="{{isAdmin}}">
    <button class="btn-primary" style="margin-bottom: 20rpx;" bindtap="goEdit">编辑教程</button>
    <button class="btn-danger" bindtap="handleDelete">删除教程</button>
  </view>
</view>
