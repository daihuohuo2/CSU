.summary-card {
  margin-bottom: 0;
}

.summary-row {
  display: flex;
  text-align: center;
  margin-bottom: 20rpx;
}

.summary-box {
  flex: 1;
}

.summary-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #6D3FC1;
}

.summary-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.summary-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.action-row {
  margin-top: 24rpx;
}

.import-btn {
  width: 100%;
}

.progress-text {
  margin-top: 18rpx;
  text-align: center;
  font-size: 25rpx;
  color: #999;
}

.cover-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 24rpx;
}

.cover-card {
  width: calc((100% - 20rpx) / 2);
  margin: 0;
  padding: 18rpx;
  box-sizing: border-box;
}

.cover-frame {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F5F5F5;
}

.cover-frame.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0FF 0%, #EEE6FF 100%);
}

.cover-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-placeholder-text {
  font-size: 24rpx;
  color: #8D75C2;
}

.cover-name {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  line-height: 1.5;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  text-align: center;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-subtext {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #B3B3B3;
}

.pager-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.pager-btn {
  flex: 1;
  padding-left: 0;
  padding-right: 0;
}

.pager-text {
  min-width: 140rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}
