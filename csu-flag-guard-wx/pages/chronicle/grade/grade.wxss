.summary-card {
  margin-bottom: 24rpx;
}

.summary-row {
  display: flex;
  text-align: center;
  margin-bottom: 20rpx;
}

.summary-box {
  flex: 1;
}

.summary-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #6D3FC1;
}

.summary-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.summary-tip {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
}

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.import-btn,
.select-btn {
  flex: 1;
}

.progress-text {
  margin-top: 18rpx;
  text-align: center;
  font-size: 25rpx;
  color: #999;
}

.cover-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 8rpx 24rpx 0;
}

.cover-card {
  position: relative;
  width: calc((100% - 20rpx) / 2);
  margin: 0;
  padding: 18rpx;
  box-sizing: border-box;
}

.cover-card.selected {
  box-shadow: 0 0 0 3rpx rgba(196, 26, 26, 0.14);
}

.select-badge {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  z-index: 2;
  font-size: 22rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.92);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #E5E5E5;
}

.select-badge.active {
  color: #C41A1A;
  border-color: #F2B9B9;
  background: #FFF2F2;
}

.cover-frame {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F5F5F5;
}

.cover-frame.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0FF 0%, #EEE6FF 100%);
}

.cover-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-placeholder-text {
  font-size: 24rpx;
  color: #8D75C2;
}

.cover-name {
  margin-top: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  line-height: 1.5;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 240rpx;
  text-align: center;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-subtext {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #B3B3B3;
}

.pager-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.pager-btn {
  flex: 1;
  padding-left: 0;
  padding-right: 0;
}

.pager-text {
  min-width: 140rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.batch-action-bar {
  position: sticky;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(12rpx);
  border-top: 1rpx solid #F0F0F0;
  z-index: 10;
}

.batch-action-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.batch-delete-btn {
  min-width: 220rpx;
  margin: 0;
}
