.intro-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  margin-bottom: 28rpx;
}

.content-textarea {
  min-height: 480rpx;
}

.loading-card {
  min-height: 280rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.image-tip {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #999;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 20rpx;
}

.image-item,
.image-upload {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F7F7F7;
}

.image-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.image-order {
  position: absolute;
  left: 10rpx;
  top: 10rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 17rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.image-delete {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
}

.image-upload {
  border: 2rpx dashed #D9D9D9;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-plus {
  font-size: 48rpx;
  line-height: 1;
  color: #6D3FC1;
}

.upload-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #666;
}

.uploading-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #6D3FC1;
}

.submit-area {
  padding: 30rpx 24rpx 60rpx;
}
