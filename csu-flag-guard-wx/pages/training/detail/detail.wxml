<view class="container" wx:if="{{detail}}">
  <view class="card">
    <view class="detail-title">{{detail.title}}</view>
    <view class="detail-type">{{detail.type}}</view>
    <view class="info-row">
      <text class="info-label">日期</text>
      <text class="info-value">{{detail.date}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">时间</text>
      <text class="info-value">{{detail.time || '待定'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">地点</text>
      <text class="info-value">{{detail.location || '待定'}}</text>
    </view>
    <view class="info-row" wx:if="{{detail.description}}">
      <text class="info-label">描述</text>
      <text class="info-value">{{detail.description}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-header">考勤统计</view>
    <view class="stats-row">
      <view class="stat-box">
        <view class="stat-num" style="color: #333;">{{stats.total}}</view>
        <view class="stat-label">总人数</view>
      </view>
      <view class="stat-box">
        <view class="stat-num" style="color: #07C160;">{{stats.arrived || 0}}</view>
        <view class="stat-label">已到</view>
      </view>
      <view class="stat-box">
        <view class="stat-num" style="color: #FFA500;">{{stats.late || 0}}</view>
        <view class="stat-label">迟到</view>
      </view>
      <view class="stat-box">
        <view class="stat-num" style="color: #EE0000;">{{stats.absent || 0}}</view>
        <view class="stat-label">缺勤</view>
      </view>
      <view class="stat-box">
        <view class="stat-num" style="color: #576B95;">{{stats.leave || 0}}</view>
        <view class="stat-label">请假</view>
      </view>
    </view>
  </view>

  <view class="card">
    <view class="section-header">考勤明细</view>
    <block wx:if="{{detail.attendance.length}}">
      <view class="att-item" wx:for="{{detail.attendance}}" wx:key="memberId">
        <view class="att-name">{{item.name}}</view>
        <view wx:if="{{isAdmin}}" class="att-status-selector">
          <view class="att-status-btn {{item.status === statusKeys.arrived ? 'active-green' : ''}}" bindtap="changeStatus" data-index="{{index}}" data-status="{{statusKeys.arrived}}">已到</view>
          <view class="att-status-btn {{item.status === statusKeys.late ? 'active-orange' : ''}}" bindtap="changeStatus" data-index="{{index}}" data-status="{{statusKeys.late}}">迟到</view>
          <view class="att-status-btn {{item.status === statusKeys.absent ? 'active-red' : ''}}" bindtap="changeStatus" data-index="{{index}}" data-status="{{statusKeys.absent}}">缺勤</view>
          <view class="att-status-btn {{item.status === statusKeys.leave ? 'active-blue' : ''}}" bindtap="changeStatus" data-index="{{index}}" data-status="{{statusKeys.leave}}">请假</view>
        </view>
        <view wx:else class="status-badge" style="background: {{statusColors[item.status]}};">{{item.status}}</view>
      </view>
    </block>
    <view wx:else class="member-empty">当前暂无参与成员</view>
  </view>

  <view class="bottom-actions" wx:if="{{isMakeupTraining || isAdmin}}">
    <button wx:if="{{isMakeupTraining}}" class="btn-primary action-btn" bindtap="handleJoinMakeup" loading="{{isJoiningMakeup}}">参加补训</button>
    <button wx:if="{{isAdmin}}" class="btn-danger action-btn" bindtap="handleDelete">删除此训练</button>
  </view>
</view>
