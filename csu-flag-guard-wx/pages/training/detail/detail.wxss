.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.detail-type {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #FFF0F0;
  color: #C41A1A;
  margin-bottom: 20rpx;
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-box {
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 考勤明细 */
.att-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.att-item:last-child {
  border-bottom: none;
}

.att-name {
  font-size: 28rpx;
  font-weight: bold;
  min-width: 100rpx;
}

.att-status-selector {
  display: flex;
  gap: 8rpx;
}

.att-status-btn {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  color: #999999;
}

.att-status-btn.active-green {
  background: #E8F5E9;
  color: #07C160;
  font-weight: bold;
}

.att-status-btn.active-orange {
  background: #FFF3E0;
  color: #FFA500;
  font-weight: bold;
}

.att-status-btn.active-red {
  background: #FFEBEE;
  color: #EE0000;
  font-weight: bold;
}

.att-status-btn.active-blue {
  background: #E8EAF6;
  color: #576B95;
  font-weight: bold;
}

/* 底部操作 */
.bottom-actions {
  padding: 30rpx 24rpx;
}
