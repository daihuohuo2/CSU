.record-header,
.schedule-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.record-title,
.schedule-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.record-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.record-status.pending {
  background: #FFF0F0;
  color: #C41A1A;
}

.record-status.assigned {
  background: #F0F5FF;
  color: #576B95;
}

.record-status.scheduled {
  background: #FFF6E8;
  color: #E6A23C;
}

.record-meta,
.schedule-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #666666;
}

.record-tip {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #F0F5FF;
  color: #576B95;
  font-size: 24rpx;
}

.action-row {
  margin-top: 20rpx;
}

.action-btn {
  width: 100%;
}

.section-tip {
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.schedule-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.selected {
  background: #FAFCFF;
}

.schedule-action {
  font-size: 22rpx;
  color: #C41A1A;
}

.empty-inline {
  font-size: 24rpx;
  color: #999999;
  padding: 12rpx 0;
}
