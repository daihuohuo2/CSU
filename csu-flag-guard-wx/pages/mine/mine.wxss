.profile-header {
  background: linear-gradient(135deg, #8B0000 0%, #C41A1A 100%);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.profile-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.profile-role.admin {
  color: #FFD700;
}

.menu-card {
  padding: 0 30rpx;
}

.mine-menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.mine-menu-item:last-child {
  border-bottom: none;
}

.mine-menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 44rpx;
  text-align: center;
}

.mine-menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.menu-badge.danger {
  background: #FFF0F0;
  color: #C41A1A;
}

.menu-badge.normal {
  background: #F0F5FF;
  color: #576B95;
}

.menu-badge.scheduled {
  background: #FFF6E8;
  color: #E6A23C;
}

/* BUG反馈卡片 */
.bug-card {
  padding: 30rpx;
}

.bug-card .form-group {
  margin-bottom: 24rpx;
}

.bug-card .form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.bug-card .form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #FAFAFA;
}

.bug-card .form-textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  min-height: 160rpx;
  background: #FAFAFA;
}

.bug-submit-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #C41A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  margin-top: 10rpx;
}

.bug-submit-btn::after {
  border: none;
}

/* 退出登录卡片 */
.logout-card {
  margin-bottom: 20rpx;
}
