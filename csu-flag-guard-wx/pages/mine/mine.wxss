.profile-header {
  background: linear-gradient(135deg, #8B0000 0%, #C41A1A 100%);
  padding: 60rpx 40rpx 50rpx;
  display: flex;
  align-items: center;
}

.profile-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.profile-role {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.profile-role.admin {
  color: #FFD700;
}

.menu-card {
  padding: 0 30rpx;
}

.mine-menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.mine-menu-item:last-child {
  border-bottom: none;
}

.mine-menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  width: 44rpx;
  text-align: center;
}

.mine-menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.menu-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.menu-badge.danger {
  background: #FFF0F0;
  color: #C41A1A;
}

.menu-badge.normal {
  background: #F0F5FF;
  color: #576B95;
}

.menu-badge.scheduled {
  background: #FFF6E8;
  color: #E6A23C;
}
