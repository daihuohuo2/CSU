.reporter-bar {
  margin-bottom: 28rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #FFF6E8;
}

.reporter-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.reporter-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #A85C00;
}

.report-tip {
  margin: 10rpx 0 28rpx;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.7;
}
