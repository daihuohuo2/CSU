.login-header {
  text-align: center;
  padding: 100rpx 0 60rpx;
}

.login-flag {
  font-size: 80rpx;
  color: #C41A1A;
  margin-bottom: 16rpx;
}

.login-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #8B0000;
}

.login-subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 10rpx;
}

.login-form {
  margin: 0 40rpx;
}

.role-selector {
  display: flex;
  gap: 20rpx;
}

.role-option {
  flex: 1;
  text-align: center;
  padding: 30rpx 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  background: #FAFAFA;
  position: relative;
}

.role-option.active {
  border-color: #C41A1A;
  background: #FFF5F5;
}

.role-icon-text {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.role-name {
  font-size: 26rpx;
  color: #666666;
}

.role-option.active .role-name {
  color: #C41A1A;
  font-weight: bold;
}

.role-check {
  position: absolute;
  top: 10rpx;
  right: 14rpx;
  font-size: 24rpx;
  color: #C41A1A;
  font-weight: bold;
}

.login-btn {
  margin-top: 50rpx;
  width: 100%;
}

.login-tip {
  text-align: center;
  margin-top: 40rpx;
  padding: 0 60rpx;
  color: #BBBBBB;
  font-size: 24rpx;
}
