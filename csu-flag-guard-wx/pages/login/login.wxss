.login-page {
  min-height: 100vh;
  background: #F2F2F2;
  display: flex;
  flex-direction: column;
}

/* 背景图区域 */
.login-bg {
  width: 100%;
  height: 620rpx;
  position: relative;
  overflow: hidden;
}

.login-bg-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 底部渐变遮罩：图片 → 页面底色平滑过渡 */
.login-bg-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(to bottom, rgba(242,242,242,0) 0%, rgba(242,242,242,0.6) 50%, rgba(242,242,242,1) 100%);
  z-index: 1;
}

/* 左上角徽章组 */
.login-emblems {
  position: absolute;
  top: 80rpx;
  left: 32rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  z-index: 2;
}

.login-badge {
  width: 60rpx;
  height: 60rpx;
}

.login-star {
  font-size: 40rpx;
  color: #FFD700;
  line-height: 1;
  text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.4);
}

/* 登录表单卡片 — 下移，减少遮挡 */
.login-form {
  width: 650rpx;
  margin: -60rpx auto 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 44rpx 40rpx 50rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.12);
  position: relative;
  z-index: 2;
}

.login-form-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B0000;
  text-align: center;
  letter-spacing: 4rpx;
}

.login-form-subtitle {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #FAFAFA;
}

.password-row {
  display: flex;
  align-items: center;
  position: relative;
}

.password-input {
  flex: 1;
  padding-right: 100rpx;
}

.password-eye {
  position: absolute;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #C41A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  margin-top: 10rpx;
  letter-spacing: 8rpx;
}

.login-btn::after {
  border: none;
}

/* 底部提示 */
.login-tip {
  text-align: center;
  padding: 30rpx 40rpx;
  font-size: 24rpx;
  color: #999;
}
