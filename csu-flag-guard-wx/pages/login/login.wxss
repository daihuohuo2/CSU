.login-page {
  min-height: 100vh;
  background: #F2F2F2;
  display: flex;
  flex-direction: column;
}

/* 顶部背景区 - 对齐截图样式 */
.login-bg {
  width: 100%;
  height: 520rpx;
  background: linear-gradient(180deg, #8B0000 0%, #C41A1A 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 60rpx;
}

.login-emblems {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 28rpx;
}

.login-badge {
  width: 90rpx;
  height: 90rpx;
}

.login-star {
  font-size: 56rpx;
  color: #FFD700;
  line-height: 1;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 6rpx;
}

.login-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 12rpx;
  letter-spacing: 4rpx;
}

/* 登录表单卡片 */
.login-form {
  width: 650rpx;
  margin: -80rpx auto 0;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 2;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #FAFAFA;
}

.password-row {
  display: flex;
  align-items: center;
  position: relative;
}

.password-input {
  flex: 1;
  padding-right: 100rpx;
}

.password-eye {
  position: absolute;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #C41A1A;
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  text-align: center;
  margin-top: 10rpx;
  letter-spacing: 8rpx;
}

.login-btn::after {
  border: none;
}

/* 底部提示 */
.login-tip {
  text-align: center;
  padding: 30rpx 40rpx;
  font-size: 24rpx;
  color: #999;
}
