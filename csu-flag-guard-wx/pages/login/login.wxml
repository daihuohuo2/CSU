<view class="login-page">
  <!-- 顶部背景区 -->
  <view class="login-bg">
    <view class="login-emblems">
      <image class="login-badge" src="/mock/university.png" mode="aspectFit" />
      <text class="login-star">★</text>
      <image class="login-badge" src="/mock/class.png" mode="aspectFit" />
    </view>
    <view class="login-title">中南大学国旗班</view>
    <view class="login-subtitle">智慧管理系统</view>
  </view>

  <!-- 登录表单卡片 -->
  <view class="login-form">
    <view class="form-group">
      <text class="form-label">学号</text>
      <input class="form-input" placeholder="请输入学号或手机号" value="{{studentId}}" bindinput="onStudentIdInput" type="text"
        maxlength="20" />
    </view>

    <view class="form-group">
      <text class="form-label">密码</text>
      <view class="password-row">
        <input class="form-input password-input" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput"
          password="{{!passwordVisible}}" />
        <view class="password-eye" bindtap="togglePasswordVisible">
          <text>{{passwordVisible ? '隐藏' : '显示'}}</text>
        </view>
      </view>
    </view>

    <button class="login-btn" bindtap="handleLogin">登 录</button>
  </view>

  <view class="login-tip">
    <text>账号与密码：23级之后（含）为学号，23级之前为手机号</text>
  </view>
</view>
