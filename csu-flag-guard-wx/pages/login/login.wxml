<view class="container">
  <view class="login-header">
    <view class="login-flag">★</view>
    <view class="login-title">中南大学国旗班</view>
    <view class="login-subtitle">管理系统登录</view>
  </view>

  <view class="login-form card">
    <view class="form-group">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-group">
      <text class="form-label">选择身份</text>
      <view class="role-selector">
        <view class="role-option {{role === 'member' ? 'active' : ''}}" bindtap="selectRole" data-role="member">
          <view class="role-icon-text">👤</view>
          <view class="role-name">普通成员</view>
          <view class="role-check" wx:if="{{role === 'member'}}">✓</view>
        </view>
        <view class="role-option {{role === 'admin' ? 'active' : ''}}" bindtap="selectRole" data-role="admin">
          <view class="role-icon-text">👑</view>
          <view class="role-name">管理员</view>
          <view class="role-check" wx:if="{{role === 'admin'}}">✓</view>
        </view>
      </view>
    </view>

    <button class="btn-primary login-btn" bindtap="handleLogin">登 录</button>
  </view>

  <view class="login-tip">
    <text>提示：当前为模拟登录，选择角色即可体验对应功能</text>
  </view>
</view>
