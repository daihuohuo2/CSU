<view class="container">
  <view class="login-header">
    <view class="login-flag">★</view>
    <view class="login-title">中南大学国旗班</view>
    <view class="login-subtitle">管理系统登录</view>
  </view>

  <view class="login-form card">
    <view class="form-group">
      <text class="form-label">学号</text>
      <input class="form-input" placeholder="请输入学号" value="{{studentId}}" bindinput="onStudentIdInput" type="number"
        maxlength="20" />
    </view>

    <view class="form-group">
      <text class="form-label">密码</text>
      <view class="password-row">
        <input class="form-input password-input" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput"
          password="{{!passwordVisible}}" />
        <view class="password-eye" bindtap="togglePasswordVisible">
          <text>{{passwordVisible ? '隐藏' : '显示'}}</text>
        </view>
      </view>
    </view>

    <button class="btn-primary login-btn" bindtap="handleLogin">登 录</button>
  </view>

  <view class="login-tip">
    <text>默认密码：123456　班长、副班长及各部门负责人自动获得管理员权限</text>
  </view>
</view>
