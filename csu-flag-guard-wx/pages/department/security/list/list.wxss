.banner-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.banner-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: #FFF3F0;
  color: #C94B2C;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.banner-body {
  flex: 1;
}

.banner-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.banner-subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  line-height: 1.8;
}

.stats-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-box {
  flex: 1;
  min-width: 130rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.stat-num {
  font-size: 38rpx;
  font-weight: bold;
  color: #333333;
}

.stat-num.pending {
  color: #C41A1A;
}

.stat-num.scheduled {
  color: #E6A23C;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.module-card {
  border: 2rpx solid #FFF1EC;
}

.module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.module-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.module-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #FFF3F0;
  color: #C94B2C;
}

.module-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

.module-action {
  margin-top: 20rpx;
  text-align: right;
  font-size: 24rpx;
  color: #C94B2C;
}
