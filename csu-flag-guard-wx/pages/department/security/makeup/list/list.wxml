<view class="container" wx:if="{{isAdmin}}">
  <view class="card intro-card">
    <view class="section-header">补训记录总览</view>
    <view class="intro-text">按成员展示待补训、待参加与补训总次数，默认按补训总次数从高到低排列。</view>
  </view>

  <view class="card table-card" wx:if="{{summaries.length}}">
    <view class="table-head">
      <text class="col-member">成员</text>
      <text class="col-pending">待补训</text>
      <text class="col-upcoming">待参加</text>
      <text class="col-total">总次数</text>
    </view>
    <view
      class="table-row"
      wx:for="{{summaries}}"
      wx:key="id"
      bindtap="goDetail"
      data-member-id="{{item.id}}"
    >
      <view class="col-member member-cell">
        <view class="member-name">{{item.name}}</view>
        <view class="member-sub">{{item.positionText || '未设职务'}}{{item.department ? ' · ' + item.department : ''}}</view>
      </view>
      <text class="col-pending pending">{{item.makeupPendingCount}}</text>
      <text class="col-upcoming upcoming">{{item.makeupUpcomingCount}}</text>
      <text class="col-total total">{{item.makeupTotalCount}}</text>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!isLoading}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">当前没有补训统计数据</view>
  </view>
</view>
