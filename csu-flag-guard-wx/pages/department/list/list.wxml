<view class="container" wx:if="{{isAdmin}}">
  <view class="card intro-card">
    <view class="section-header">部门管理</view>
    <view class="intro-text">以下为管理员可用的部门子菜单，可按部门进入后续管理工作。</view>
  </view>

  <view class="department-list">
    <view class="department-item card" wx:for="{{departments}}" wx:key="key" bindtap="handleDepartmentTap" data-key="{{item.key}}" data-name="{{item.name}}">
      <view class="department-icon" style="background: {{item.bgColor}}; color: {{item.color}};">{{item.icon}}</view>
      <view class="department-body">
        <view class="department-name">{{item.name}}</view>
        <view class="department-desc">{{item.desc}}</view>
      </view>
      <text class="arrow-right">›</text>
    </view>
  </view>
</view>
