.empty-wrap {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
}

.loading-spinner {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  border: 8rpx solid #F0D3D3;
  border-top-color: #C41A1A;
  animation: spin 0.9s linear infinite;
}

.empty-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
}

.dept-banner {
  display: flex;
  align-items: center;
}

.dept-banner-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dept-banner-body {
  flex: 1;
}

.dept-banner-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.dept-banner-subtitle {
  font-size: 24rpx;
  color: #999;
  line-height: 1.7;
  margin-top: 8rpx;
}

.dept-banner-tag {
  display: inline-block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #576B95;
  background: #F0F5FF;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.placeholder-box {
  background: #FAFAFA;
  border: 2rpx dashed #E5E5E5;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
}

.placeholder-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.8;
  margin-top: 12rpx;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
