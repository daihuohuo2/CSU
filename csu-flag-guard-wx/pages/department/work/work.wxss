.empty-wrap {
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
}

.loading-spinner {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  border: 8rpx solid #F0D3D3;
  border-top-color: #C41A1A;
  animation: spin 0.9s linear infinite;
}

.empty-title {
  margin-top: 28rpx;
  font-size: 30rpx;
  color: #666666;
  line-height: 1.8;
}

.dept-banner {
  display: flex;
  align-items: center;
}

.dept-banner-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.dept-banner-body {
  flex: 1;
}

.dept-banner-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333333;
}

.dept-banner-subtitle {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.7;
  margin-top: 8rpx;
}

.dept-banner-tag {
  display: inline-block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #576B95;
  background: #F0F5FF;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.member-summary {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.member-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.member-item:last-child {
  border-bottom: none;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.member-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999999;
}

.member-position {
  font-size: 22rpx;
  color: #666666;
  background: #F5F5F5;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.task-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.done {
  opacity: 0.92;
}

.task-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
}

.task-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #999999;
}

.task-action {
  margin-top: 14rpx;
  text-align: right;
  font-size: 24rpx;
  color: #6B4EFF;
}

.placeholder-box {
  background: #FAFAFA;
  border: 2rpx dashed #E5E5E5;
  border-radius: 16rpx;
  padding: 30rpx 24rpx;
}

.placeholder-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666666;
}

.placeholder-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
  margin-top: 12rpx;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
