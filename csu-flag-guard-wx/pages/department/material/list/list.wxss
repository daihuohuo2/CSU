.intro-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.8;
}

.upload-entry-card {
  border: 2rpx solid #F1E9FF;
}

.upload-entry-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.upload-entry-desc {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

.upload-entry-action {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #6B4EFF;
}

.record-card {
  margin-top: 20rpx;
}

.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  min-width: 0;
  word-break: break-all;
}

.record-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F0FF;
  color: #6B4EFF;
  flex-shrink: 0;
}

.record-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #777777;
  word-break: break-all;
}

.record-action {
  margin-top: 18rpx;
  text-align: right;
  font-size: 24rpx;
  color: #6B4EFF;
}

.record-panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 300;
  display: flex;
  align-items: flex-end;
}

.record-panel {
  width: 100%;
  background: #FFFFFF;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 24rpx 36rpx;
  box-sizing: border-box;
}

.record-panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.record-panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.record-panel-close {
  font-size: 24rpx;
  color: #999999;
}

.file-card {
  padding: 24rpx;
  border: 2rpx dashed #D8D8D8;
  border-radius: 12rpx;
  background: #FAFAFA;
}

.file-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  word-break: break-all;
}

.file-placeholder {
  font-size: 26rpx;
  color: #999999;
}

.file-size {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #999999;
}

.submit-btn {
  margin-top: 10rpx;
}
