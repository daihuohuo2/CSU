.position-summary {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.position-summary.placeholder {
  color: #999;
}

.position-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.position-item:last-child {
  border-bottom: none;
}

.position-name {
  font-size: 28rpx;
  color: #333;
}

.submit-area {
  padding: 30rpx 24rpx 60rpx;
}
