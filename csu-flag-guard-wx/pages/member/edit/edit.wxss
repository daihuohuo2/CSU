.edit-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.edit-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.header-action {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #FFF0F0;
  color: #C41A1A;
  font-size: 24rpx;
  font-weight: 600;
}

.position-summary {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 24rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.position-summary.placeholder {
  color: #999;
}

.form-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.position-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.position-item:last-child {
  border-bottom: none;
}

.position-name {
  font-size: 28rpx;
  color: #333;
}

.submit-area {
  padding: 30rpx 24rpx 60rpx;
}
