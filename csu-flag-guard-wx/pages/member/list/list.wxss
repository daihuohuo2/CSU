.filter-toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
}

.filter-toolbar .filter-bar {
  flex: 1;
  padding: 0;
  background: transparent;
}

.toolbar-action {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 30rpx;
  background: #FFF0F0;
  color: #C41A1A;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.toolbar-action.active {
  background: #C41A1A;
  color: #FFF;
}

.batch-tip-bar {
  padding: 0 24rpx 12rpx;
  color: #666;
  font-size: 24rpx;
}

.member-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.member-card.selected {
  border: 2rpx solid #C41A1A;
  box-shadow: 0 8rpx 20rpx rgba(196, 26, 26, 0.12);
}

.member-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #D9D9D9;
  color: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  font-size: 24rpx;
}

.member-check.checked {
  background: #C41A1A;
  border-color: #C41A1A;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B0000, #C41A1A);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.member-pos {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  background: #FFF0F0;
  color: #C41A1A;
}

.member-sub {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.status-active {
  background: #E8F5E9;
  color: #07C160;
}

.status-inactive {
  background: #F5F5F5;
  color: #999999;
}

.batch-action-bar {
  position: sticky;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx 40rpx;
  background: linear-gradient(180deg, rgba(242, 242, 242, 0), #F2F2F2 24rpx);
}

.batch-action-btn {
  flex: 1;
}
