.member-card {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B0000, #C41A1A);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.member-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.member-pos {
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  background: #FFF0F0;
  color: #C41A1A;
}

.member-sub {
  font-size: 24rpx;
  color: #999999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.status-active {
  background: #E8F5E9;
  color: #07C160;
}

.status-inactive {
  background: #F5F5F5;
  color: #999999;
}
