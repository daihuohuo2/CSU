.detail-header {
  background: linear-gradient(135deg, #8B0000 0%, #C41A1A 100%);
  padding: 50rpx 40rpx;
  text-align: center;
}

.detail-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  color: #FFFFFF;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.detail-pos {
  font-size: 26rpx;
  color: #FFD700;
  margin-top: 8rpx;
}

.bottom-actions {
  padding: 30rpx 24rpx 60rpx;
}
