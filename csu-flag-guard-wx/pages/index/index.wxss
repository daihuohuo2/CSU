.header {
  background: linear-gradient(135deg, #8B0000 0%, #C41A1A 100%);
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
}

.header-flag {
  font-size: 60rpx;
  color: #FFD700;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  align-items: center;
  margin-top: -20rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #C41A1A;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.user-role-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #999999;
  background: #F5F5F5;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  margin-top: 6rpx;
  width: fit-content;
}

.user-role-tag.admin-tag {
  color: #C41A1A;
  background: #FFF0F0;
}

.login-prompt {
  justify-content: space-between;
  margin-top: -20rpx;
}

.login-text {
  color: #999999;
  font-size: 28rpx;
}

.login-btn-text {
  color: #C41A1A;
  font-size: 28rpx;
  font-weight: bold;
}

/* 功能入口 */
.menu-grid {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
}

.menu-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-body {
  flex: 1;
}

.menu-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.menu-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 6rpx;
}

/* 快捷操作 */
.quick-list {
  padding: 10rpx 30rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.quick-item:last-child {
  border-bottom: none;
}

.quick-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.quick-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #CCCCCC;
}
