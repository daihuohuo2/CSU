.list-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.list-item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  flex: 1;
}

.flag-type-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.flag-type-tag.up {
  background: #FFF0F0;
  color: #C41A1A;
}

.flag-type-tag.down {
  background: #FFF8E6;
  color: #E6A23C;
}

.list-item-info {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #999999;
}

.list-item-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.stat-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}
