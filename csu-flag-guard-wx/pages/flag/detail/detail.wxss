.detail-top-actions {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 20rpx;
}

.detail-edit-btn {
  font-size: 24rpx;
  color: #C41A1A;
  background: #FFF2F2;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.flag-type-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.flag-type-tag.up {
  background: #FFF0F0;
  color: #C41A1A;
}

.flag-type-tag.down {
  background: #FFF8E6;
  color: #E6A23C;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  text-align: center;
}

.stat-box {
  flex: 1;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
}

.stat-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

.att-group + .att-group {
  margin-top: 24rpx;
}

.att-group-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #666666;
  margin-bottom: 8rpx;
}

.att-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.att-item:last-child {
  border-bottom: none;
}

.att-name {
  font-size: 28rpx;
  font-weight: bold;
  min-width: 100rpx;
}

.att-status-selector {
  display: flex;
  gap: 8rpx;
}

.att-status-btn {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: #F5F5F5;
  color: #999999;
}

.att-status-btn.active-green {
  background: #E8F5E9;
  color: #07C160;
  font-weight: bold;
}

.att-status-btn.active-orange {
  background: #FFF3E0;
  color: #FFA500;
  font-weight: bold;
}

.att-status-btn.active-red {
  background: #FFEBEE;
  color: #EE0000;
  font-weight: bold;
}

.att-status-btn.active-blue {
  background: #E8EAF6;
  color: #576B95;
  font-weight: bold;
}

.bottom-actions {
  padding: 30rpx 24rpx;
}
